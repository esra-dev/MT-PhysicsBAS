    ws:connSource lab:EffLight_Z1 ; ws:connTarget lab:LightSensor_Z1 ;
    elem:hasStructuralStereotype ws:PrimaryOpticalCoupling .

ws:conn_IneffZ1_to_LSz1 a owl:NamedIndividual, elem:InternalConnection ;
