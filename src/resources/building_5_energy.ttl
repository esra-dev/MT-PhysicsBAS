# ===========================================================================
# 9.  STATE VECTOR SLOT REGISTRY  (length 10)
#  [Z1Level,Z2Level,Z1Eff,Z1Ineff,Z2Eff,Z2Ineff,Z1Blinds,Z2Blinds,Spotlight,Sunshine]
# ===========================================================================

lab:Slot_ZoneLevel_Z1
    ws:stateVecIndex   0 ; ws:stateDomainSize 4 ; ws:stateSlotRole "zone_level" ; ws:zoneIndex 1 .

lab:Slot_ZoneLevel_Z2
    ws:stateVecIndex   1 ; ws:stateDomainSize 4 ; ws:stateSlotRole "zone_level" ; ws:zoneIndex 2 .

lab:Slot_Sunshine
    ws:stateVecIndex   9 ; ws:stateDomainSize 4 ; ws:stateSlotRole "sunshine" .


