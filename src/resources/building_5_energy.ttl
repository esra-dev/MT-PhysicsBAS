ws:SetZ1Eff_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:EffLight_Z1 elem:hasComponentAction ws:SetZ1Eff_ON, ws:SetZ1Eff_OFF .

