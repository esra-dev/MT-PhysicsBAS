@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

@prefix brick:  <https://brickschema.org/schema/Brick#> .
@prefix elem:   <http://w3id.org/elementary#> .
@prefix qudt:   <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .

@prefix lab:    <http://example.org/was/lab#> .
@prefix ws:     <http://example.org/was/lab/stereotypes#> .

# ===========================================================================
#  LAB 4 — SMART-PLUG DEPENDENCY  (Phase 4 clean lab, dependency variant)
# ---------------------------------------------------------------------------
#  SELF-CONTAINED domain ontology. Loaded via ont(["building_4_smartplug.ttl"])
#  WITHOUT lab-ontology.ttl. Forked from building_3_complex.ttl (lab3) and adds
#  exactly ONE hidden DEPENDENCY: the Workstation-1 ceiling lamp is wired
#  through a SMART PLUG. The lamp emits light ONLY when BOTH its own switch is
#  ON *and* the smart plug is ON (an AND-gate power dependency). The plug is a
#  NEW component stereotype (ws:SmartPlugStereotype) and the dependency is fully
#  documented in the KG via ws:powerGates / ws:poweredBy. Nothing is hidden from
#  the Knowledge Graph — a KG-primed agent can read the dependency and learn to
#  enable the plug first; a tabula-rasa agent must discover it by trial-and-error.
#
#  This is a CLEAN lab (no weaknesses): the simulator reacts EXACTLY as the KG
#  documents. The dependency is a real, documented physical wiring fact, not an
#  injected fault.
#
#  Physics (simulator_flow_lab4.json, port 1897):
#     z1lamp_on = (Z1Light AND PlugZ1)          <-- the gated lamp
#     Z1Level = 25 + (z1lamp_on?400:0) + (Z2Light?150:0)
#                  + (Z1Blinds?0.50*Sun:0) + (Z2Blinds?0.40*Sun:0) + (Spotlight?150:0)
#     Z2Level = 25 + (Z2Light?400:0) + (z1lamp_on?150:0)
#                  + (Z2Blinds?0.50*Sun:0) + (Z1Blinds?0.40*Sun:0) + (Spotlight?150:0)
#  Sunshine sampled once per episode from {0,100,400,900} and PINNED.
#  State vector = [Z1Level,Z2Level,Z1Light,Z2Light,Z1Blinds,Z2Blinds,Spotlight,PlugZ1,Sunshine]
#                = 4*4*2*2*2*2*2*2*4 = 4096 states.
#  New feature vs. Lab 3: a smart-plug power dependency on the Z1 lamp.
# ===========================================================================


# ===========================================================================
# Property declarations (self-contained)
# ===========================================================================

brick:feeds   owl:equivalentProperty elem:feeds .
sosa:observes owl:equivalentProperty elem:observes .

elem:increases a owl:ObjectProperty ;
    rdfs:label "increases (Causes shortcut)" .

ws:zoneIndex a owl:DatatypeProperty ;
    rdfs:label "Zone index" ; rdfs:range xsd:integer .

ws:ivMinRank a owl:DatatypeProperty ;
    rdfs:label "Minimum effective IV rank" ; rdfs:range xsd:integer .

ws:actionValue a owl:DatatypeProperty ;
    rdfs:label "Action boolean value" ; rdfs:range xsd:boolean .

ws:rankBound_1 a owl:DatatypeProperty ; rdfs:range xsd:decimal .
ws:rankBound_2 a owl:DatatypeProperty ; rdfs:range xsd:decimal .
ws:rankBound_3 a owl:DatatypeProperty ; rdfs:range xsd:decimal .

ws:hasWoTActionSemanticType a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
ws:hasWoTStateSemanticType  a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
ws:stateVecIndex   a owl:DatatypeProperty ; rdfs:range xsd:integer .
ws:stateDomainSize a owl:DatatypeProperty ; rdfs:range xsd:integer .
ws:stateSlotRole   a owl:DatatypeProperty ; rdfs:range xsd:string .

# Connection (coupling) endpoints — used to reify a brick:feeds arc as an
# explicit elem:InternalConnection carrying a coupling stereotype (see §4b/§7b).
ws:connSource a owl:ObjectProperty ; rdfs:label "connection source component" .
ws:connTarget a owl:ObjectProperty ; rdfs:label "connection target component" .

# --- Phase 4 (lab4): smart-plug power-dependency predicates -----------------
# ws:powerGates  — the smart plug is the power gate that ENABLES the lamp.
#                  (subject = enabling actuator, object = gated actuator)
# ws:poweredBy   — inverse view: the lamp receives its electrical power THROUGH
#                  the plug. Both directions are stated so either can be queried.
ws:powerGates a owl:ObjectProperty ;
    rdfs:label "powers / gates (electrical enable dependency)" .
ws:poweredBy a owl:ObjectProperty ;
    rdfs:label "powered by (receives electrical power through)" ;
    owl:inverseOf ws:powerGates .


# ===========================================================================
# 1.  PHYSICAL MECHANISMS
# ===========================================================================

ws:pm_incandescent_light_emission a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_incandescent_light_emission" ;
    elem:hasManipulatedVariable elem:electrical_power_input ;
    elem:hasDependentVariable   elem:luminiscence ;
    elem:increases              elem:luminiscence .

ws:pm_daylight_ingress a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_daylight_ingress through blind aperture" ;
    elem:hasIndependentVariable ws:outdoorIlluminance ;
    elem:hasManipulatedVariable ws:blindApertureRatio ;
    elem:hasDependentVariable   elem:luminiscence ;
    ws:ivMinRank                1 .

# Spotlight: Causes (high-power, unconditional, shared across both zones).
ws:pm_spotlight_illumination a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_spotlight_illumination" ;
    elem:hasManipulatedVariable ws:spotlightPowerInput ;
    elem:hasDependentVariable   elem:luminiscence ;
    elem:increases              elem:luminiscence .

# Smart plug: switched mains supply. The plug gates the electrical inlet of the
# Z1 lamp; the dependent variable is luminiscence (transitively, via the lamp it
# powers) so the actuator-discovery query treats the plug as a light-affecting
# actuator the agent can act on. The AND-gate dependency itself is declared
# separately by ws:powerGates (§5b).
ws:pm_switched_power_supply a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_switched_power_supply (smart plug mains gate)" ;
    elem:hasManipulatedVariable ws:plugPowerSwitch ;
    elem:hasDependentVariable   elem:luminiscence ;
    elem:increases              elem:luminiscence .

ws:illuminanceSensing a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "Illuminance sensing" ;
    elem:hasIndependentVariable elem:luminiscence ;
    elem:hasDependentVariable   ws:sensedIlluminance .

ws:pm_outdoor_light_emission a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_outdoor_light_emission" ;
    elem:hasDependentVariable   ws:outdoorIlluminance .

ws:outdoorIlluminanceSensing a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "Outdoor illuminance sensing" ;
    elem:hasIndependentVariable ws:outdoorIlluminance ;
    elem:hasDependentVariable   ws:sensedOutdoorIlluminance .


# ===========================================================================
# 2.  PROCESS VARIABLES
# ===========================================================================

elem:electrical_power_input a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Electrical power input to light" ;
    elem:dealsWithStuff  elem:electrical_power ;
    elem:hasProcessPosition elem:inlet ;
    elem:hasQuantity     qudtqk:ActivePower .

ws:plugPowerSwitch a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Smart-plug mains switch (on/off)" ;
    elem:dealsWithStuff  elem:electrical_power ;
    elem:hasProcessPosition elem:inlet ;
    elem:hasQuantity     qudtqk:ActivePower .

ws:spotlightPowerInput a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Spotlight power switch (on/off)" ;
    elem:dealsWithStuff  elem:electrical_power ;
    elem:hasProcessPosition elem:inlet ;
    elem:hasQuantity     qudtqk:ActivePower .

ws:outdoorIlluminance a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Outdoor illuminance (sunshine)" ;
    elem:dealsWithStuff  elem:photons ;
    elem:hasProcessPosition elem:inlet ;
    elem:hasQuantity     qudtqk:Illuminance .

ws:blindApertureRatio a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Blind aperture ratio (open vs. closed)" ;
    elem:dealsWithStuff  ws:MechanicalPosition ;
    elem:hasProcessPosition elem:inlet ;
    elem:hasQuantity     qudtqk:DimensionlessRatio .

elem:luminiscence a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Indoor illuminance level" ;
    elem:dealsWithStuff  elem:photons ;
    elem:hasProcessPosition elem:outlet ;
    elem:hasQuantity     qudtqk:Illuminance .

ws:sensedIlluminance a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Sensed indoor illuminance signal" ;
    elem:dealsWithStuff  elem:photons ;
    elem:hasProcessPosition elem:outlet ;
    elem:hasQuantity     qudtqk:Illuminance ;
    ws:rankBound_1       "50"^^xsd:decimal ;
    ws:rankBound_2       "100"^^xsd:decimal ;
    ws:rankBound_3       "300"^^xsd:decimal .

ws:sensedOutdoorIlluminance a owl:NamedIndividual, elem:ProcessVariable ;
    rdfs:label "Sensed outdoor illuminance signal" ;
    elem:dealsWithStuff  elem:photons ;
    elem:hasProcessPosition elem:outlet ;
    elem:hasQuantity     qudtqk:Illuminance ;
    ws:rankBound_1       "50"^^xsd:decimal ;
    ws:rankBound_2       "200"^^xsd:decimal ;
    ws:rankBound_3       "600"^^xsd:decimal .


# ===========================================================================
# 3.  PHYSICAL STUFF + STREAM KINDS
# ===========================================================================

elem:photons a owl:NamedIndividual, elem:PhysicalStuff ;
    rdfs:label "Visible light (photons)" .

ws:MechanicalPosition a owl:NamedIndividual, elem:PhysicalStuff ;
    rdfs:label "Mechanical position / aperture" .

ws:IndoorLightingStream a owl:NamedIndividual, elem:StreamKind ;
    rdfs:label "Indoor lighting stream" .

ws:OutdoorSunlightStream a owl:NamedIndividual, elem:StreamKind ;
    rdfs:label "Outdoor sunlight stream" .

# Sub-rank cross-zone optical coupling (lamp +150 lux / blind 0.40·Sun spill).
ws:SecondaryCouplingStream a owl:NamedIndividual, elem:StreamKind ;
    rdfs:label "Secondary (cross-zone) optical coupling stream" .

# Electrical supply stream — the smart plug feeds the lamp through this.
ws:ElectricalSupplyStream a owl:NamedIndividual, elem:StreamKind ;
    rdfs:label "Switched electrical supply stream (plug -> lamp)" .


# ===========================================================================
# 4.  COMPONENT STEREOTYPES
# ===========================================================================

ws:LampIncandescentStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Incandescent lamp stereotype" ;
    elem:hasPhysicalMechanism ws:pm_incandescent_light_emission ;
    elem:hasConnectionPoint  ws:cp_light_electrical_inlet ;
    elem:hasConnectionPoint  ws:cp_light_photon_outlet .

ws:cp_light_electrical_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Electrical inlet of incandescent lamp" ;
    elem:dealsWithStuff elem:electrical_power ;
    elem:manipulates    elem:electrical_power_input .

ws:cp_light_photon_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Photon (light) outlet of incandescent lamp" ;
    elem:dealsWithStuff        elem:photons ;
    elem:isRelatedToVariable   elem:luminiscence ;
    elem:suitableFor           ws:IndoorLightingStream .

# --- Smart-plug stereotype (NEW in lab4) -----------------------------------
ws:SmartPlugStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Smart plug (switched mains socket) stereotype" ;
    elem:hasPhysicalMechanism ws:pm_switched_power_supply ;
    elem:hasConnectionPoint  ws:cp_plug_mains_inlet ;
    elem:hasConnectionPoint  ws:cp_plug_switched_outlet .

ws:cp_plug_mains_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Mains inlet of smart plug" ;
    elem:dealsWithStuff elem:electrical_power ;
    elem:manipulates    ws:plugPowerSwitch .

ws:cp_plug_switched_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Switched electrical outlet of smart plug (feeds the lamp)" ;
    elem:dealsWithStuff        elem:electrical_power ;
    elem:isRelatedToVariable   ws:plugPowerSwitch ;
    elem:suitableFor           ws:ElectricalSupplyStream .

ws:BlindStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Window blind stereotype" ;
    elem:hasPhysicalMechanism ws:pm_daylight_ingress ;
    elem:hasConnectionPoint  ws:cp_blind_outdoor_inlet ;
    elem:hasConnectionPoint  ws:cp_blind_actuator_inlet ;
    elem:hasConnectionPoint  ws:cp_blind_light_outlet .

ws:cp_blind_outdoor_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Outdoor sunlight inlet of blind" ;
    elem:dealsWithStuff        elem:photons ;
    elem:isRelatedToVariable   ws:outdoorIlluminance ;
    elem:suitableFor           ws:OutdoorSunlightStream .

ws:cp_blind_actuator_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Actuator inlet of blind (Up / Down command)" ;
    elem:dealsWithStuff ws:MechanicalPosition ;
    elem:manipulates    ws:blindApertureRatio .

ws:cp_blind_light_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Indoor light outlet of blind" ;
    elem:dealsWithStuff        elem:photons ;
    elem:isRelatedToVariable   elem:luminiscence ;
    elem:suitableFor           ws:IndoorLightingStream .

ws:SpotlightStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Spotlight stereotype" ;
    elem:hasPhysicalMechanism ws:pm_spotlight_illumination ;
    elem:hasConnectionPoint  ws:cp_spotlight_electrical_inlet ;
    elem:hasConnectionPoint  ws:cp_spotlight_photon_outlet .

ws:cp_spotlight_electrical_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Electrical inlet of spotlight" ;
    elem:dealsWithStuff elem:electrical_power ;
    elem:manipulates    ws:spotlightPowerInput .

ws:cp_spotlight_photon_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Photon (light) outlet of spotlight" ;
    elem:dealsWithStuff        elem:photons ;
    elem:isRelatedToVariable   elem:luminiscence ;
    elem:suitableFor           ws:IndoorLightingStream .

ws:LightSensorStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Indoor light sensor stereotype" ;
    elem:hasPhysicalMechanism ws:illuminanceSensing ;
    elem:hasConnectionPoint  ws:cp_lightsensor_photon_inlet ;
    elem:hasConnectionPoint  ws:cp_lightsensor_signal_outlet .

ws:cp_lightsensor_photon_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Photon inlet of indoor light sensor" ;
    elem:dealsWithStuff      elem:photons ;
    elem:isRelatedToVariable elem:luminiscence ;
    elem:suitableFor         ws:IndoorLightingStream .

ws:cp_lightsensor_signal_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Measurement signal outlet of indoor light sensor" ;
    elem:dealsWithStuff      elem:photons ;
    elem:isRelatedToVariable ws:sensedIlluminance .

ws:WeatherStationStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Weather station (outdoor illuminance sensor) stereotype" ;
    elem:hasPhysicalMechanism ws:outdoorIlluminanceSensing ;
    elem:hasConnectionPoint  ws:cp_ws_photon_inlet ;
    elem:hasConnectionPoint  ws:cp_ws_signal_outlet .

ws:cp_ws_photon_inlet a owl:NamedIndividual, elem:InletConnectionPoint ;
    rdfs:label "Photon inlet of weather station" ;
    elem:dealsWithStuff      elem:photons ;
    elem:isRelatedToVariable ws:outdoorIlluminance ;
    elem:suitableFor         ws:OutdoorSunlightStream .

ws:cp_ws_signal_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Measurement signal outlet of weather station" ;
    elem:dealsWithStuff      elem:photons ;
    elem:isRelatedToVariable ws:sensedOutdoorIlluminance .

ws:OutsideStereotype a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Outdoor light source (sun) stereotype" ;
    elem:hasPhysicalMechanism ws:pm_outdoor_light_emission ;
    elem:hasConnectionPoint  ws:cp_outside_light_outlet .

ws:cp_outside_light_outlet a owl:NamedIndividual, elem:OutletConnectionPoint ;
    rdfs:label "Outdoor light outlet (sun)" ;
    elem:dealsWithStuff      elem:photons ;
    elem:isRelatedToVariable ws:outdoorIlluminance ;
    elem:suitableFor         ws:OutdoorSunlightStream .


# ===========================================================================
# 4b. CONNECTION (COUPLING) STEREOTYPES
# ===========================================================================

ws:pm_primary_illumination_transfer a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_primary_illumination_transfer (dominant same-zone, rank-moving)" ;
    elem:hasDependentVariable elem:luminiscence ;
    elem:increases            elem:luminiscence .

ws:pm_secondary_illumination_transfer a owl:NamedIndividual, elem:PhysicalMechanism ;
    rdfs:label "pm_secondary_illumination_transfer (sub-rank cross-zone spill)" ;
    elem:hasDependentVariable elem:luminiscence ;
    elem:increases            elem:luminiscence .

ws:PrimaryOpticalCoupling a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Primary optical coupling (dominant, rank-moving) connection stereotype" ;
    elem:hasPhysicalMechanism ws:pm_primary_illumination_transfer ;
    elem:hasStreamKind        ws:IndoorLightingStream .

ws:WeakOpticalCoupling a owl:NamedIndividual, elem:Stereotype ;
    rdfs:label "Weak optical coupling (cross-zone light spill) connection stereotype" ;
    elem:hasPhysicalMechanism ws:pm_secondary_illumination_transfer ;
    elem:hasStreamKind        ws:SecondaryCouplingStream .


# ===========================================================================
# 5.  BUILDING TOPOLOGY (two coupled zones + shared spotlight)
# ===========================================================================

lab:Workstation a owl:Class ;
    rdfs:label "Workstation" ;
    rdfs:subClassOf brick:Space .

lab:SmartPlugBuilding a brick:Building ;
    rdfs:label "Lab 4 (Smart-Plug) Building" ;
    brick:hasPart lab:Lab .

lab:Lab a brick:Room ;
    rdfs:label "Lab 4 room" ;
    brick:hasPart lab:Zone1 ;
    brick:hasPart lab:Zone2 .

lab:Zone1 a lab:Workstation ;
    rdfs:label "Workstation 1" ;
    brick:isLocatedIn lab:Lab ;
    ws:zoneIndex 1 .

lab:Zone2 a lab:Workstation ;
    rdfs:label "Workstation 2" ;
    brick:isLocatedIn lab:Lab ;
    ws:zoneIndex 2 .


# ===========================================================================
# 5b. POWER DEPENDENCY  (the hidden-but-documented smart-plug wiring)
# ---------------------------------------------------------------------------
#  The Z1 ceiling lamp is electrically downstream of the smart plug: the lamp is
#  powered THROUGH the plug, so it can only emit light when the plug is ON.
#  This is stated in BOTH directions so a consumer may query either way.
# ===========================================================================

lab:SmartPlug_Z1   ws:powerGates  lab:CeilingLight_Z1 .
lab:CeilingLight_Z1 ws:poweredBy   lab:SmartPlug_Z1 .


# ===========================================================================
# 6.  COMPONENT INSTANCES
# ===========================================================================

lab:Indoor_Illuminance_Sensor_Equipment a owl:Class ;
    rdfs:label "Indoor illuminance sensor equipment" ;
    rdfs:subClassOf brick:Sensor_Equipment .

lab:CeilingLight_Z1 a brick:Luminaire, elem:Actuator ;
    rdfs:label "Incandescent lamp – Workstation 1 (powered through the smart plug)" ;
    brick:isLocatedIn lab:Zone1 ;
    elem:hasBehavioralStereotype ws:LampIncandescentStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

lab:CeilingLight_Z2 a brick:Luminaire, elem:Actuator ;
    rdfs:label "Incandescent lamp – Workstation 2" ;
    brick:isLocatedIn lab:Zone2 ;
    elem:hasBehavioralStereotype ws:LampIncandescentStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

# Smart plug located in Zone 1; gates the Z1 lamp (see §5b).
lab:SmartPlug_Z1 a brick:Equipment, elem:Actuator ;
    rdfs:label "Smart plug – Workstation 1 (powers the Z1 ceiling lamp)" ;
    brick:isLocatedIn lab:Zone1 ;
    elem:hasBehavioralStereotype ws:SmartPlugStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

lab:Blind_Z1 a brick:Blind, elem:Actuator ;
    rdfs:label "Window blind – Workstation 1" ;
    brick:isLocatedIn lab:Zone1 ;
    elem:hasBehavioralStereotype ws:BlindStereotype ;
    elem:isPartOf      lab:IndoorLightingStream ;
    elem:isPartOf      lab:OutdoorSunlightStream .

lab:Blind_Z2 a brick:Blind, elem:Actuator ;
    rdfs:label "Window blind – Workstation 2" ;
    brick:isLocatedIn lab:Zone2 ;
    elem:hasBehavioralStereotype ws:BlindStereotype ;
    elem:isPartOf      lab:IndoorLightingStream ;
    elem:isPartOf      lab:OutdoorSunlightStream .

# Spotlight — single shared unit located in BOTH zones so the actuator query
# returns it once per zone (affects both zones equally, +150 lux).
lab:Spotlight a brick:Luminaire, elem:Actuator ;
    rdfs:label "Shared high-lux spotlight" ;
    brick:isLocatedIn lab:Zone1 ;
    brick:isLocatedIn lab:Zone2 ;
    elem:hasBehavioralStereotype ws:SpotlightStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

lab:LightSensor_Z1 a lab:Indoor_Illuminance_Sensor_Equipment, elem:Sensor ;
    rdfs:label "Indoor illuminance sensor – Workstation 1" ;
    brick:isLocatedIn lab:Zone1 ;
    sosa:observes     lab:IndoorIlluminance_Z1 ;
    elem:hasBehavioralStereotype ws:LightSensorStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

lab:LightSensor_Z2 a lab:Indoor_Illuminance_Sensor_Equipment, elem:Sensor ;
    rdfs:label "Indoor illuminance sensor – Workstation 2" ;
    brick:isLocatedIn lab:Zone2 ;
    sosa:observes     lab:IndoorIlluminance_Z2 ;
    elem:hasBehavioralStereotype ws:LightSensorStereotype ;
    elem:isPartOf      lab:IndoorLightingStream .

lab:WeatherStation a brick:Weather_Station, elem:Sensor ;
    rdfs:label "Outdoor weather station" ;
    brick:isLocatedIn lab:SmartPlugBuilding ;
    sosa:observes     lab:OutdoorIlluminance ;
    elem:hasBehavioralStereotype ws:WeatherStationStereotype ;
    elem:isPartOf      lab:OutdoorSunlightStream .

lab:Outside a owl:NamedIndividual ;
    rdfs:label "Outdoor light source (sun)" ;
    elem:hasBehavioralStereotype ws:OutsideStereotype ;
    elem:isPartOf      lab:OutdoorSunlightStream .

lab:IndoorLightingStream a elem:Stream ;
    rdfs:label "Indoor lighting process stream (shared)" ;
    elem:hasStreamKind ws:IndoorLightingStream .

lab:OutdoorSunlightStream a elem:Stream ;
    rdfs:label "Outdoor sunlight stream" ;
    elem:hasStreamKind ws:OutdoorSunlightStream .

lab:IndoorIlluminance_Z1 a sosa:ObservableProperty ;
    rdfs:label "Indoor illuminance – Workstation 1" ;
    qudt:hasQuantityKind qudtqk:Illuminance .

lab:IndoorIlluminance_Z2 a sosa:ObservableProperty ;
    rdfs:label "Indoor illuminance – Workstation 2" ;
    qudt:hasQuantityKind qudtqk:Illuminance .

lab:OutdoorIlluminance a sosa:ObservableProperty ;
    rdfs:label "Outdoor illuminance (sunshine)" ;
    qudt:hasQuantityKind qudtqk:Illuminance .


# ===========================================================================
# 7.  TOPOLOGICAL CONNECTIONS  (same-zone + sun + CROSS-ZONE spill)
# ===========================================================================

# Sun → weather station + both blinds.
lab:Outside          brick:feeds  lab:WeatherStation .
lab:Outside          brick:feeds  lab:Blind_Z1 .
lab:Outside          brick:feeds  lab:Blind_Z2 .

# Primary illumination (same zone).
lab:CeilingLight_Z1  brick:feeds  lab:LightSensor_Z1 .
lab:CeilingLight_Z2  brick:feeds  lab:LightSensor_Z2 .
lab:Blind_Z1         brick:feeds  lab:LightSensor_Z1 .
lab:Blind_Z2         brick:feeds  lab:LightSensor_Z2 .

# Cross-zone spill (matches the +150 lamp and +0.40*Sun blind bleed terms).
lab:CeilingLight_Z1  brick:feeds  lab:LightSensor_Z2 .
lab:CeilingLight_Z2  brick:feeds  lab:LightSensor_Z1 .
lab:Blind_Z1         brick:feeds  lab:LightSensor_Z2 .
lab:Blind_Z2         brick:feeds  lab:LightSensor_Z1 .


# ---------------------------------------------------------------------------
# 7b. REIFIED CONNECTIONS (coupling class per arc)
# ---------------------------------------------------------------------------
ws:conn_CLz1_to_LSz2 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Cross-zone spill: CeilingLight_Z1 -> LightSensor_Z2 (+150 lux)" ;
    ws:connSource lab:CeilingLight_Z1 ; ws:connTarget lab:LightSensor_Z2 ;
    elem:hasStructuralStereotype ws:WeakOpticalCoupling .

ws:conn_CLz2_to_LSz1 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Cross-zone spill: CeilingLight_Z2 -> LightSensor_Z1 (+150 lux)" ;
    ws:connSource lab:CeilingLight_Z2 ; ws:connTarget lab:LightSensor_Z1 ;
    elem:hasStructuralStereotype ws:WeakOpticalCoupling .

ws:conn_BZ1_to_LSz2 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Cross-zone spill: Blind_Z1 -> LightSensor_Z2 (0.40*Sun)" ;
    ws:connSource lab:Blind_Z1 ; ws:connTarget lab:LightSensor_Z2 ;
    elem:hasStructuralStereotype ws:WeakOpticalCoupling .

ws:conn_BZ2_to_LSz1 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Cross-zone spill: Blind_Z2 -> LightSensor_Z1 (0.40*Sun)" ;
    ws:connSource lab:Blind_Z2 ; ws:connTarget lab:LightSensor_Z1 ;
    elem:hasStructuralStereotype ws:WeakOpticalCoupling .

ws:conn_CLz1_to_LSz1 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Same-zone primary: CeilingLight_Z1 -> LightSensor_Z1 (+400 lux)" ;
    ws:connSource lab:CeilingLight_Z1 ; ws:connTarget lab:LightSensor_Z1 ;
    elem:hasStructuralStereotype ws:PrimaryOpticalCoupling .

ws:conn_CLz2_to_LSz2 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Same-zone primary: CeilingLight_Z2 -> LightSensor_Z2 (+400 lux)" ;
    ws:connSource lab:CeilingLight_Z2 ; ws:connTarget lab:LightSensor_Z2 ;
    elem:hasStructuralStereotype ws:PrimaryOpticalCoupling .

ws:conn_BZ1_to_LSz1 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Same-zone primary: Blind_Z1 -> LightSensor_Z1 (0.50*Sun)" ;
    ws:connSource lab:Blind_Z1 ; ws:connTarget lab:LightSensor_Z1 ;
    elem:hasStructuralStereotype ws:PrimaryOpticalCoupling .

ws:conn_BZ2_to_LSz2 a owl:NamedIndividual, elem:InternalConnection ;
    rdfs:label "Same-zone primary: Blind_Z2 -> LightSensor_Z2 (0.50*Sun)" ;
    ws:connSource lab:Blind_Z2 ; ws:connTarget lab:LightSensor_Z2 ;
    elem:hasStructuralStereotype ws:PrimaryOpticalCoupling .


# ===========================================================================
# 8.  COMPONENT ACTIONS
# ===========================================================================

ws:SetZ1Light_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetZ1Light_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:CeilingLight_Z1 elem:hasComponentAction ws:SetZ1Light_ON, ws:SetZ1Light_OFF .

ws:SetZ2Light_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetZ2Light_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:CeilingLight_Z2 elem:hasComponentAction ws:SetZ2Light_ON, ws:SetZ2Light_OFF .

ws:SetPlugZ1_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetPlugZ1_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:SmartPlug_Z1 elem:hasComponentAction ws:SetPlugZ1_ON, ws:SetPlugZ1_OFF .

ws:SetZ1Blinds_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetZ1Blinds_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:Blind_Z1 elem:hasComponentAction ws:SetZ1Blinds_ON, ws:SetZ1Blinds_OFF .

ws:SetZ2Blinds_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetZ2Blinds_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:Blind_Z2 elem:hasComponentAction ws:SetZ2Blinds_ON, ws:SetZ2Blinds_OFF .

ws:SetSpotlight_ON  a elem:ComponentAction ; ws:actionValue "true"^^xsd:boolean .
ws:SetSpotlight_OFF a elem:ComponentAction ; ws:actionValue "false"^^xsd:boolean .
lab:Spotlight elem:hasComponentAction ws:SetSpotlight_ON, ws:SetSpotlight_OFF .


# ===========================================================================
# 9.  STATE VECTOR SLOT REGISTRY  (length 9)
#  [Z1Level,Z2Level,Z1Light,Z2Light,Z1Blinds,Z2Blinds,Spotlight,PlugZ1,Sunshine]
# ===========================================================================

lab:Slot_ZoneLevel_Z1
    ws:stateVecIndex   0 ; ws:stateDomainSize 4 ; ws:stateSlotRole "zone_level" ; ws:zoneIndex 1 .

lab:Slot_ZoneLevel_Z2
    ws:stateVecIndex   1 ; ws:stateDomainSize 4 ; ws:stateSlotRole "zone_level" ; ws:zoneIndex 2 .

lab:Slot_Sunshine
    ws:stateVecIndex   8 ; ws:stateDomainSize 4 ; ws:stateSlotRole "sunshine" .


# ===========================================================================
# 10.  WoT ACTION / STATE MAPPINGS  (the discovery gate)
# ===========================================================================

lab:CeilingLight_Z1
    ws:hasWoTActionSemanticType "http://example.org/was#SetZ1Light" ;
    ws:hasWoTStateSemanticType  "http://example.org/was#Z1Light" ;
