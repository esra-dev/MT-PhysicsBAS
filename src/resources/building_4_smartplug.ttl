    ws:stateVecIndex            6 ; ws:stateDomainSize 2 ; ws:stateSlotRole "boolean_actuator" .

lab:SmartPlug_Z1
    ws:hasWoTActionSemanticType "http://example.org/was#SetPlugZ1" ;
