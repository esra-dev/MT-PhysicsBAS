@prefix td:     <https://www.w3.org/2019/wot/td#> .
@prefix hctl:   <https://www.w3.org/2019/wot/hypermedia#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix eve:    <http://w3id.org/eve#> .
@prefix wotsec: <https://www.w3.org/2019/wot/security#> .
@prefix js:     <https://www.w3.org/2019/wot/json-schema#> .
@prefix htv:    <http://www.w3.org/2011/http#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
#  LAB 5 — ENERGY Thing Description (port 1898).
#  Forked from Lab 3. Two coupled zones + shared Spotlight. NEW: each zone has
#  TWO directly-actionable ceiling lamps with identical light output (+400 lux)
#  but different energy cost — an EFFICIENT lamp (1/tick) and an INEFFICIENT
#  lamp (4/tick). Status carries both zone levels, all actuator states (four
#  lamps + two blinds + spotlight), and the pinned Sunshine rank.
#  Deterministic physics (no PRNG term).
# ============================================================================

<urn:mt-esra:interactions-lab5> a td:Thing, eve:Artifact, <https://example.org/was#Lab> ;

    td:title "The lab of the Interactions team – Lab 5 Energy" ;
    td:hasSecurityConfiguration [ a wotsec:NoSecurityScheme ] ;
    td:hasBase <http://localhost:1898/was/rl/> ;

    td:hasPropertyAffordance [
        a td:PropertyAffordance, <https://example.org/was#Status>, js:ObjectSchema ;
        td:name "Status" ;
        dct:title "Read the lab status" ;
        td:hasForm [
            htv:methodName "GET" ;
            hctl:hasTarget <http://localhost:1898/was/rl/status> ;
            hctl:forContentType "application/json" ;
            hctl:hasOperationType td:readProperty
        ] ;
        td:isObservable false ;
        js:properties
            [ a js:NumberSchema, <http://example.org/was#Z1Level> ;
              js:propertyName "Z1Level" ],
            [ a js:NumberSchema, <http://example.org/was#Z2Level> ;
              js:propertyName "Z2Level" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Eff> ;
              js:propertyName "Z1Eff" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Ineff> ;
              js:propertyName "Z1Ineff" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Eff> ;
              js:propertyName "Z2Eff" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Ineff> ;
              js:propertyName "Z2Ineff" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Blinds> ;
              js:propertyName "Z1Blinds" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Blinds> ;
              js:propertyName "Z2Blinds" ],
            [ a js:BooleanSchema, <http://example.org/was#Spotlight> ;
              js:propertyName "Spotlight" ],
            [ a js:NumberSchema, <http://example.org/was#Sunshine> ;
              js:propertyName "Sunshine" ],
            [ a js:NumberSchema, <http://example.org/was#TotalEnergyCost> ;
              js:propertyName "TotalEnergyCost" ],
            [ a js:NumberSchema, <http://example.org/was#EnergyCost> ;
              js:propertyName "EnergyCost" ],
            [ a js:NumberSchema, <http://example.org/was#Hour> ;
              js:propertyName "Hour" ]
    ] ;

    td:hasActionAffordance
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Eff> ;
          td:name "Control Efficient Lamp Z1" ;
          dct:title "Turn on and off the efficient (low-energy) lamp in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Eff" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Ineff> ;
          td:name "Control Inefficient Lamp Z1" ;
          dct:title "Turn on and off the inefficient (high-energy) lamp in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Ineff" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Eff> ;
          td:name "Control Efficient Lamp Z2" ;
          dct:title "Turn on and off the efficient (low-energy) lamp in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Eff" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Ineff> ;
          td:name "Control Inefficient Lamp Z2" ;
          dct:title "Turn on and off the inefficient (high-energy) lamp in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Ineff" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Blinds> ;
          td:name "Control Blinds Z1" ;
          dct:title "Raise and lower the blinds in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Blinds" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Blinds> ;
          td:name "Control Blinds Z2" ;
          dct:title "Raise and lower the blinds in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Blinds" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetSpotlight> ;
          td:name "Control Spotlight" ;
          dct:title "Turn on and off the shared spotlight (affects both zones equally, +150 lux)" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1898/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Spotlight" ]
          ]
        ] .
