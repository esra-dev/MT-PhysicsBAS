@prefix td:     <https://www.w3.org/2019/wot/td#> .
@prefix hctl:   <https://www.w3.org/2019/wot/hypermedia#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix eve:    <http://w3id.org/eve#> .
@prefix wotsec: <https://www.w3.org/2019/wot/security#> .
@prefix js:     <https://www.w3.org/2019/wot/json-schema#> .
@prefix htv:    <http://www.w3.org/2011/http#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<urn:mt-esra:interactions-lab-custom> a td:Thing, eve:Artifact, <https://example.org/was#Lab> ;

    td:title "The lab of the Interactions team – Custom Simulation" ;
    td:hasSecurityConfiguration [ a wotsec:NoSecurityScheme ] ;
    td:hasBase <http://localhost:1881/was/rl/> ;

    td:hasPropertyAffordance [
        a td:PropertyAffordance, <https://example.org/was#Status>, js:ObjectSchema ;
        td:name "Status" ;
        dct:title "Read the lab status" ;
        td:hasForm [
            htv:methodName "GET" ;
            hctl:hasTarget <http://localhost:1881/was/rl/status> ;
            hctl:forContentType "application/json" ;
            hctl:hasOperationType td:readProperty
        ] ;
        td:isObservable false ;
        js:properties
            [ a js:NumberSchema, <http://example.org/was#Z1Level> ;
              js:propertyName "Z1Level" ],
            [ a js:NumberSchema, <http://example.org/was#Z2Level> ;
              js:propertyName "Z2Level" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Light> ;
              js:propertyName "Z1Light" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Light> ;
              js:propertyName "Z2Light" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Blinds> ;
              js:propertyName "Z1Blinds" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Blinds> ;
              js:propertyName "Z2Blinds" ],
            [ a js:BooleanSchema, <http://example.org/was#Spotlight> ;
              js:propertyName "Spotlight" ],
            [ a js:BooleanSchema, <http://example.org/was#Z1Radiator> ;
              js:propertyName "Z1Radiator" ],
            [ a js:BooleanSchema, <http://example.org/was#Z2Radiator> ;
              js:propertyName "Z2Radiator" ],
            [ a js:NumberSchema, <http://example.org/was#Z1Temp> ;
              js:propertyName "Z1Temp" ],
            [ a js:NumberSchema, <http://example.org/was#Z2Temp> ;
              js:propertyName "Z2Temp" ],
            [ a js:NumberSchema, <http://example.org/was#Sunshine> ;
              js:propertyName "Sunshine" ],
            [ a js:NumberSchema, <http://example.org/was#TotalEnergyCost> ;
              js:propertyName "TotalEnergyCost" ],
            [ a js:NumberSchema, <http://example.org/was#EnergyCost> ;
              js:propertyName "EnergyCost" ],
            [ a js:NumberSchema, <http://example.org/was#Hour> ;
              js:propertyName "Hour" ]
    ] ;

    td:hasActionAffordance
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Light> ;
          td:name "Control Lights Z1" ;
          dct:title "Turn on and off the lights in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Light" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Light> ;
          td:name "Control Lights Z2" ;
          dct:title "Turn on and off the lights in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Light" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Blinds> ;
          td:name "Control Blinds Z1" ;
          dct:title "Raise and lower the blinds in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Blinds" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Blinds> ;
          td:name "Control Blinds Z2" ;
          dct:title "Raise and lower the blinds in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Blinds" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetSpotlight> ;
          td:name "Control Spotlight" ;
          dct:title "Turn on and off the shared high-lux spotlight (affects both zones equally)" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Spotlight" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ1Radiator> ;
          td:name "Control Radiator Z1" ;
          dct:title "Turn on and off the radiator in Z1" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z1Radiator" ]
          ]
        ],
        [ a td:ActionAffordance, <http://example.org/was#SetZ2Radiator> ;
          td:name "Control Radiator Z2" ;
          dct:title "Turn on and off the radiator in Z2" ;
          td:hasForm [
              htv:methodName "POST" ;
              hctl:hasTarget <http://localhost:1881/was/rl/action> ;
              hctl:forContentType "application/json" ;
              hctl:hasOperationType td:invokeAction
          ] ;
          td:hasInputSchema [ a js:ObjectSchema ;
              js:properties [ a js:BooleanSchema ; js:propertyName "Z2Radiator" ]
          ]
        ] .
